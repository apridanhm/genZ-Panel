# Panel Configuration
PANEL_DOMAIN=panel.example.com
SERVER_IP=YOUR_SERVER_IP
LETSENCRYPT_EMAIL=admin@example.com

# Database
POSTGRES_USER=panel
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=panel

# Security
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_64_CHARS
TRAEFIK_DASHBOARD_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# Timezone
TZ=Asia/Jakarta

# Logging
LOG_LEVEL=info

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# Mail Configuration
MAIL_HOSTNAME=mail.example.com
MAIL_RELAY_HOST=
MAIL_RELAY_PORT=587
MAIL_RELAY_USER=
MAIL_RELAY_PASSWORD=